{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/labodj/labo-smart-home/schemas/lsh_stack.schema.json",
  "title": "Labo Smart Home Stack Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "core", "platformio"],
  "properties": {
    "schema_version": { "const": 1 },
    "core": {
      "type": "object",
      "additionalProperties": false,
      "required": ["devices"],
      "properties": {
        "devices": { "type": "string", "minLength": 1 },
        "tool": { "type": "string", "minLength": 1 },
        "selected_devices": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["serial_bridge", "onboard_ethernet"] }
      }
    },
    "mqtt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "codec": { "enum": ["auto", "json", "msgpack"] },
        "lsh_base_path": { "type": "string", "pattern": ".+/$" },
        "homie_base_path": { "type": "string", "pattern": ".+/$" },
        "service_topic": { "type": "string", "minLength": 1 }
      }
    },
    "coordinator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "other_devices_prefix": { "type": "string", "minLength": 1 },
        "click_timeout": { "$ref": "#/$defs/duration" },
        "click_cleanup_interval": { "$ref": "#/$defs/duration" },
        "watchdog_interval": { "$ref": "#/$defs/duration" },
        "interrogate_threshold": { "$ref": "#/$defs/duration" },
        "ping_timeout": { "$ref": "#/$defs/duration" },
        "initial_state_timeout": { "$ref": "#/$defs/duration" },
        "other_actors_topic": { "type": "string", "minLength": 1 }
      }
    },
    "node_red": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expose_state_context": { "$ref": "#/$defs/context" },
        "expose_state_key": { "type": "string", "minLength": 1 },
        "export_topics": { "$ref": "#/$defs/context" },
        "export_topics_key": { "type": "string", "minLength": 1 },
        "expose_config_context": { "$ref": "#/$defs/context" },
        "expose_config_key": { "type": "string", "minLength": 1 },
        "other_actors_context": { "enum": ["flow", "global"] }
      }
    },
    "platformio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["core_profiles", "bridge_profiles"],
      "properties": {
        "core_project": { "type": "string", "minLength": 1 },
        "bridge_project": { "type": "string", "minLength": 1 },
        "core_extra_script": { "type": "string", "minLength": 1 },
        "core_profiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/coreProfile" },
          "minItems": 1,
          "uniqueItems": true,
          "allOf": [
            {
              "contains": {
                "type": "object",
                "required": ["default"],
                "properties": { "default": { "const": true } }
              },
              "minContains": 1,
              "maxContains": 1
            }
          ]
        },
        "core_env_prefix": { "type": "string", "minLength": 1 },
        "bridge_env_prefix": { "type": "string", "minLength": 1 },
        "core_prefer_system_tools": { "type": "boolean" },
        "bridge_profiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/bridgeProfile" },
          "minItems": 1,
          "uniqueItems": true,
          "allOf": [
            {
              "contains": {
                "type": "object",
                "required": ["default"],
                "properties": { "default": { "const": true } }
              },
              "minContains": 1,
              "maxContains": 1
            }
          ]
        }
      }
    },
    "deploy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bridge": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "default_method": { "enum": ["usb", "ota"] },
            "usb_port_template": { "type": "string", "minLength": 1 },
            "ota": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "broker_host": { "type": "string", "minLength": 1 },
                "broker_port": { "type": "integer", "minimum": 1 },
                "broker_username": { "type": "string", "minLength": 1 },
                "broker_username_env": {
                  "type": "string",
                  "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
                },
                "broker_password": { "type": "string", "minLength": 1 },
                "broker_password_env": {
                  "type": "string",
                  "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
                },
                "base_topic": { "type": "string", "pattern": ".+/$" },
                "homie_version": { "enum": ["3", "4", "5"] },
                "timeout": { "type": "integer", "minimum": 1 },
                "broker_tls_cacert": { "type": "string", "minLength": 1 },
                "broker_tls_certfile": { "type": "string", "minLength": 1 },
                "broker_tls_keyfile": { "type": "string", "minLength": 1 },
                "broker_tls_insecure": { "type": "boolean" }
              },
              "allOf": [
                { "not": { "required": ["broker_username", "broker_username_env"] } },
                { "not": { "required": ["broker_password", "broker_password_env"] } },
                {
                  "if": {
                    "anyOf": [
                      { "required": ["broker_password"] },
                      { "required": ["broker_password_env"] }
                    ]
                  },
                  "then": {
                    "anyOf": [
                      { "required": ["broker_username"] },
                      { "required": ["broker_username_env"] }
                    ]
                  }
                }
              ],
              "dependentRequired": {
                "broker_tls_keyfile": ["broker_tls_certfile"]
              }
            },
            "devices": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "usb_port": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    },
    "bridge": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaults": { "$ref": "#/$defs/bridgeOverrides" }
      }
    },
    "external_actors": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "state_key": { "type": "string", "minLength": 1 }
        }
      }
    },
    "network_clicks": {
      "type": "array",
      "items": { "$ref": "#/$defs/networkClick" }
    }
  },
  "$defs": {
    "context": { "enum": ["none", "flow", "global"] },
    "duration": {
      "oneOf": [
        { "type": "number", "exclusiveMinimum": 0 },
        { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?(ms|s|m|h)$" }
      ]
    },
    "actuatorRef": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "integer", "minimum": 1, "maximum": 255 }
      ]
    },
    "defineValue": {
      "oneOf": [{ "type": "boolean" }, { "type": "integer" }, { "type": "string" }]
    },
    "defines": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
      "additionalProperties": { "$ref": "#/$defs/defineValue" },
      "allOf": [
        { "not": { "required": ["CONFIG_HOMIE_FIRMWARE_VERSION"] } },
        {
          "properties": {
            "HOMIE_CONVENTION_VERSION": {
              "oneOf": [{ "const": 5 }, { "const": "5" }]
            }
          }
        }
      ]
    },
    "bridgeBuildFlags": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "append": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "bridgeOverrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defines": { "$ref": "#/$defs/defines" },
        "build_flags": { "$ref": "#/$defs/bridgeBuildFlags" }
      }
    },
    "coreProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "extends"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "extends": { "type": "string", "minLength": 1 },
        "default": { "type": "boolean" }
      }
    },
    "bridgeProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "extends"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "not": { "enum": ["usb", "ota", "batch", "all"] }
        },
        "extends": { "type": "string", "minLength": 1 },
        "default": { "type": "boolean" },
        "ota": { "type": "boolean" }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device", "actuators"],
      "properties": {
        "device": { "type": "string", "minLength": 1 },
        "actuators": {
          "oneOf": [
            { "const": "all" },
            {
              "type": "array",
              "items": { "$ref": "#/$defs/actuatorRef" },
              "minItems": 1,
              "uniqueItems": true
            }
          ]
        }
      }
    },
    "networkClick": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {
        "source": {
          "type": "string",
          "pattern": "^[^.]+\\.[^.]+$"
        },
        "type": { "enum": ["long", "super_long"] },
        "actors": {
          "type": "array",
          "items": { "$ref": "#/$defs/actor" }
        },
        "other_actors": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "anyOf": [
        { "required": ["actors"], "properties": { "actors": { "minItems": 1 } } },
        {
          "required": ["other_actors"],
          "properties": { "other_actors": { "minItems": 1 } }
        }
      ]
    }
  }
}
